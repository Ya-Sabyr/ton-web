# TonCenter JSON-RPC endpoint
# Testnet: https://testnet.toncenter.com/api/v2/jsonRPC
# Mainnet: https://toncenter.com/api/v2/jsonRPC
VITE_TONCENTER_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC

# TonCenter API key (increases rate limit from 1 req/s to 10 req/s)
# Get your own:
#   Testnet: https://t.me/tontestnetapibot
#   Mainnet: https://t.me/tonapibot
VITE_TONCENTER_API_KEY=

# TON workchain (0 = basechain, -1 = masterchain)
VITE_WORKCHAIN=0

# How often to poll balance, in milliseconds (default: 15000 = 15s)
VITE_BALANCE_POLL_INTERVAL=15000

# Transaction cache lifetime, in milliseconds (default: 300000 = 5min)
VITE_TX_CACHE_TTL=300000

# Block explorer base URL for transaction links
# Testnet: https://testnet.tonscan.org
# Mainnet: https://tonscan.org
VITE_TONSCAN_URL=https://testnet.tonscan.org
